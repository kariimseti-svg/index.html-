function buildWilayaList(){
  if(!S.delivery)S.delivery={};
  const wp=S.delivery.wilayaPrices||{};
  const defO=S.delivery.officeFee||300;
  const defH=S.delivery.homeFee||600;
  let html='';
  WILAYAS.forEach(w=>{
    const key=w.split(' - ')[0];
    const wd=wp[key]||{};
    html+='<div class="w-row">'+
      '<div style="font-size:13px;font-weight:600">'+w+'</div>'+
      '<input class="w-inp '+(wd.office!=null?'custom':'')+'" type="number" id="wpo-'+key+'" value="'+(wd.office!=null?wd.office:'')+'" placeholder="'+defO+'" min="0" oninput="this.classList.toggle('custom',this.value!=='')">'+
      '<input class="w-inp '+(wd.home!=null?'custom':'')+'" type="number" id="wph-'+key+'" value="'+(wd.home!=null?wd.home:'')+'" placeholder="'+defH+'" min="0" oninput="this.classList.toggle('custom',this.value!=='')">'+
      '<button class="w-clr" onclick="clrW(''+key+'')" title="مسح">↺</button>'+
    '</div>';
  });
  document.getElementById('wilaya-list').innerHTML=html;
}
function clrW(key){
  ['wpo-'+key,'wph-'+key].forEach(id=>{const el=document.getElementById(id);if(el){el.value='';el.classList.remove('custom');}});
}
function saveDelivery(){
  if(!S.delivery)S.delivery={};
  S.delivery.officeEnabled=document.getElementById('office-enabled').checked;
  S.delivery.officeFee=parseFloat(document.getElementById('office-fee').value)||300;
  S.delivery.officeTime=document.getElementById('office-time').value;
  S.delivery.company=document.getElementById('del-company').value;
  S.delivery.homeEnabled=document.getElementById('home-enabled').checked;
  S.delivery.homeFee=parseFloat(document.getElementById('home-fee').value)||600;
  S.delivery.homeTime=document.getElementById('home-time').value;
  S.delivery.freeMin=parseFloat(document.getElementById('free-min').value)||0;
  const wp={};
  WILAYAS.forEach(w=>{
    const key=w.split(' - ')[0];
    const ov=document.getElementById('wpo-'+key)?.value||'';
    const hv=document.getElementById('wph-'+key)?.value||'';
    if(ov!==''||hv!=='')wp[key]={office:ov!==''?parseFloat(ov):null,home:hv!==''?parseFloat(hv):null};
  });
  S.delivery.wilayaPrices=wp;
  saveState();
  showToast('✅ تم الحفظ — '+Object.keys(wp).length+' ولاية بسعر مخصص');
}
