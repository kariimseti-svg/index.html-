<script>
// ============================================================
// DATA LAYER
// ============================================================
const WILAYAS=[
  "01 - أدرار","02 - الشلف","03 - الأغواط","04 - أم البواقي","05 - باتنة",
  "06 - بجاية","07 - بسكرة","08 - بشار","09 - البليدة","10 - البويرة",
  "11 - تمنراست","12 - تبسة","13 - تلمسان","14 - تيارت","15 - تيزي وزو",
  "16 - الجزائر","17 - الجلفة","18 - جيجل","19 - سطيف","20 - سعيدة",
  "21 - سكيكدة","22 - سيدي بلعباس","23 - عنابة","24 - قالمة","25 - قسنطينة",
  "26 - المدية","27 - مستغانم","28 - المسيلة","29 - معسكر","30 - ورقلة",
  "31 - وهران","32 - البيض","33 - إليزي","34 - برج بوعريريج","35 - بومرداس",
  "36 - الطارف","37 - تندوف","38 - تيسمسيلت","39 - الوادي","40 - خنشلة",
  "41 - سوق أهراس","42 - تيبازة","43 - ميلة","44 - عين الدفلى","45 - النعامة",
  "46 - عين تموشنت","47 - غرداية","48 - غليزان","49 - تيميمون","50 - برج باجي مختار",
  "51 - أولاد جلال","52 - بني عباس","53 - عين صالح","54 - عين قزام","55 - تقرت",
  "56 - جانت","57 - المغير","58 - المنيعة"
];

function loadState(){
  try{const r=localStorage.getItem('storeData');if(r)return JSON.parse(r);}catch(e){}
  return null;
}
function saveState(){
  localStorage.setItem('storeData',JSON.stringify(S));
  window.dispatchEvent(new StorageEvent('storage',{key:'storeData'}));
}

const DEFAULT={
  store:{nameAr:'STORE',nameFr:'STORE',currency:'DA',phone:''},
  delivery:{homeEnabled:true,homeFee:600,homeTime:'3-5 أيام / 3-5 jours',officeEnabled:true,officeFee:300,officeTime:'2-3 أيام / 2-3 jours',freeMin:5000,company:'Yalidine'},
  products:[
    {id:1,nameAr:'سماعات لاسلكية',nameFr:'Écouteurs sans fil',descAr:'سماعات بلوتوث عالية الجودة مع عزل للضوضاء وبطارية 30 ساعة.',descFr:'Écouteurs Bluetooth haute qualité, réduction de bruit, autonomie 30h.',price:4500,emoji:'🎧',image:'',categoryAr:'إلكترونيات',categoryFr:'Électronique',stock:10,featured:true},
    {id:2,nameAr:'ساعة ذكية',nameFr:'Montre connectée',descAr:'ساعة ذكية مع قياس ضغط الدم والنبض.',descFr:'Montre intelligente avec tensiomètre et fréquence cardiaque.',price:8900,emoji:'⌚',image:'',categoryAr:'إلكترونيات',categoryFr:'Électronique',stock:5,featured:false},
    {id:3,nameAr:'حقيبة جلدية',nameFr:'Sac en cuir',descAr:'حقيبة جلد طبيعي 100% بتصميم أنيق.',descFr:'Sac en cuir véritable 100%, design élégant.',price:6500,emoji:'👜',image:'',categoryAr:'أزياء',categoryFr:'Mode',stock:8,featured:true},
  ],
  orders:[]
};

let S=loadState()||JSON.parse(JSON.stringify(DEFAULT));
if(!S.orders)S.orders=[];
if(!S.delivery)S.delivery=DEFAULT.delivery;

// ============================================================
// NAVIGATION
// ============================================================
let currentPage='dashboard';
function goPage(id,btn){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  if(btn){document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));btn.classList.add('active');}
  currentPage=id;
  if(id==='dashboard')renderDash();
  if(id==='orders')renderOrders();
  if(id==='products')renderProds();
  if(id==='delivery')loadDelivery();
  if(id==='settings')loadSettings();
  if(id==='categories')renderCats();
  if(id==='delivery')loadDelivery();
}

// ============================================================
// HELPERS
// ============================================================
const cur=()=>S.store.currency||'DA';
const fmt=n=>Number(n).toLocaleString('fr-DZ')+' '+cur();
const statusLabel={pending:'⏳ معلق',confirmed:'✅ مؤكد',delivering:'🚚 في الطريق',delivered:'🎉 تم التسليم',cancelled:'❌ ملغى'};
const statusClass={pending:'b-pending',confirmed:'b-confirmed',delivering:'b-delivering',delivered:'b-delivered',cancelled:'b-cancelled'};
const deliveryLabel={home:'🏠 للمنزل',office:'🏢 للمكتب'};
function nowStr(){return new Date().toLocaleString('ar-DZ',{year:'numeric',month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'});}
function orderNum(id){return '#ORD-'+String(id).slice(-4);}

// ============================================================
// DASHBOARD
// ============================================================
function renderDash(){
  const prods=S.products,orders=S.orders;
  document.getElementById('ds-prod').textContent=prods.length;
  document.getElementById('ds-pend').textContent=orders.filter(o=>o.status==='pending').length;
  document.getElementById('ds-deliv').textContent=orders.filter(o=>o.status==='delivered').length;
  const rev=orders.filter(o=>o.status==='delivered').reduce((s,o)=>s+o.total,0);
  document.getElementById('ds-rev').textContent=rev.toLocaleString('fr-DZ');
  const pc=orders.filter(o=>o.status==='pending').length;
  document.getElementById('pending-count').textContent=pc;
  document.getElementById('pending-count').style.display=pc>0?'inline':'none';

  // Recent orders
  const tb=document.getElementById('dash-orders');
  const recent=[...orders].sort((a,b)=>b.id-a.id).slice(0,5);
  tb.innerHTML=recent.length?recent.map(o=>`
    <tr>
      <td><b>${orderNum(o.id)}</b></td>
      <td><div class="td-name">${o.name}</div><div class="td-sub">${o.phone}</div></td>
      <td>${o.items.map(i=>i.nameAr||i.name).join('، ')}</td>
      <td><span class="badge b-price">${fmt(o.total)}</span></td>
      <td>${deliveryLabel[o.deliveryType]||o.deliveryType}</td>
      <td><span class="badge ${statusClass[o.status]}">${statusLabel[o.status]}</span></td>
      <td><button class="btn btn-info btn-xs" onclick="openOrderDetail(${o.id})">عرض</button></td>
    </tr>`).join(''):`<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--muted)">لا توجد طلبات بعد</td></tr>`;

  // Products
  const pb=document.getElementById('dash-prods');
  pb.innerHTML=prods.slice(0,5).map(p=>`
    <tr>
      <td><div class="prod-thumb">${p.image?`<img src="${p.image}">`:(p.emoji||'📦')}</div></td>
      <td><div class="td-name">${p.nameAr}</div></td>
      <td><span class="badge b-cat">${p.categoryAr||'عام'}</span></td>
      <td><span class="badge b-price">${fmt(p.price)}</span></td>
      <td><span class="badge ${p.stock>0?'b-stock':'b-out'}">${p.stock>0?p.stock+' قطعة':'نفد'}</span></td>
      <td><button class="btn btn-warning btn-xs" onclick="editProd(${p.id});goPage('products',null)">تعديل</button></td>
    </tr>`).join('');
}

// ============================================================
// ORDERS
// ============================================================
let orderFilter='all';
function setOrderFilter(f,btn){
  orderFilter=f;
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderOrders();
}

function renderOrders(){
  const q=(document.getElementById('order-srch')?.value||'').toLowerCase();
  let list=[...S.orders].sort((a,b)=>b.id-a.id);
  if(orderFilter!=='all')list=list.filter(o=>o.status===orderFilter);
  if(q)list=list.filter(o=>o.name.toLowerCase().includes(q)||String(o.id).includes(q)||o.wilaya.includes(q));
  const tb=document.getElementById('orders-table');
  tb.innerHTML=list.length?list.map(o=>`
    <tr>
      <td><b>${orderNum(o.id)}</b></td>
      <td style="font-size:11px;color:var(--muted)">${o.date||'—'}</td>
      <td><div class="td-name">${o.name}</div><div class="td-sub">${o.phone}</div></td>
      <td style="font-size:12px">${o.wilaya}</td>
      <td>${deliveryLabel[o.deliveryType]||o.deliveryType}</td>
      <td style="font-size:12px;max-width:140px">${o.items.map(i=>(i.nameAr||i.name)+' ×'+i.qty).join('<br>')}</td>
      <td><span class="badge b-price">${fmt(o.total)}</span></td>
      <td>
        <select class="status-sel" onchange="changeStatus(${o.id},this.value)">
          <option value="pending" ${o.status==='pending'?'selected':''}>⏳ معلق</option>
          <option value="confirmed" ${o.status==='confirmed'?'selected':''}>✅ مؤكد</option>
          <option value="delivering" ${o.status==='delivering'?'selected':''}>🚚 في الطريق</option>
          <option value="delivered" ${o.status==='delivered'?'selected':''}>🎉 تم التسليم</option>
          <option value="cancelled" ${o.status==='cancelled'?'selected':''}>❌ ملغى</option>
        </select>
      </td>
      <td>
        <div style="display:flex;gap:4px">
          <button class="btn btn-info btn-xs" onclick="openOrderDetail(${o.id})">👁️</button>
          <button class="btn btn-danger btn-xs" onclick="deleteOrder(${o.id})">🗑️</button>
        </div>
      </td>
