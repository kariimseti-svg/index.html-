renderDash();
window.addEventListener('storage',e=>{
  if(e.key==='storeData'){S=loadState()||JSON.parse(JSON.stringify(DEFAULT));if(currentPage==='orders')renderOrders();if(currentPage==='products')renderProds();renderDash();}
});
</script>
