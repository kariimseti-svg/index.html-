  document.querySelectorAll('#prodOverlay .tab').forEach(b=>b.classList.remove('active'));
  if(btn)btn.classList.add('active');
}

function prvImg(url){const i=document.getElementById('p-img-prev');if(url){i.src=url;i.style.display='block';}else i.style.display='none';}

function saveProd(){
  const nameAr=document.getElementById('p-nameAr').value.trim();
  const price=parseFloat(document.getElementById('p-price').value);
  if(!nameAr||!price){showToast('⚠️ الاسم العربي والسعر مطلوبان');return;}
  const prod={
    nameAr,
    nameFr:document.getElementById('p-nameFr').value.trim()||nameAr,
    descAr:document.getElementById('p-descAr').value.trim(),
    descFr:document.getElementById('p-descFr').value.trim(),
    price,
    stock:parseInt(document.getElementById('p-stock').value)||0,
    emoji:document.getElementById('p-emoji').value.trim()||'📦',
    image:document.getElementById('p-image').value.trim(),
    categoryAr:document.getElementById('p-catAr').value.trim()||'عام',
    categoryFr:document.getElementById('p-catFr').value.trim()||'Général',
    featured:document.getElementById('p-featured').checked,
  };
  if(editId){
    const i=S.products.findIndex(p=>p.id===editId);
    S.products[i]={...S.products[i],...prod};
    showToast('✅ تم تعديل المنتج بنجاح');
  }else{
    prod.id=Date.now();
    S.products.push(prod);
    showToast('✅ تمت إضافة المنتج');
  }
  saveState();renderProds();renderDash();
  document.getElementById('prodOverlay').classList.remove('show');
}

function deleteProd(id){
  if(!confirm('حذف هذا المنتج؟'))return;
  S.products=S.products.filter(p=>p.id!==id);
  saveState();renderProds();renderDash();showToast('🗑️ تم حذف المنتج');
}

function toggleFeatured(id,val){
