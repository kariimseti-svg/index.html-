let editId=null;
function renderProds(){
  const q=(document.getElementById('prod-srch')?.value||'').toLowerCase();
  const cf=document.getElementById('prod-cat-filter')?.value||'';
  let list=S.products;
  if(q)list=list.filter(p=>p.nameAr.includes(q)||p.nameFr.toLowerCase().includes(q));
  if(cf)list=list.filter(p=>p.categoryAr===cf);
  const tb=document.getElementById('prods-table');
  tb.innerHTML=list.length?list.map(p=>`
    <tr>
      <td><div class="prod-thumb">${p.image?`<img src="${p.image}" onerror="this.style.display='none'">`:(p.emoji||'📦')}</div></td>
      <td><div class="td-name">${p.nameAr}</div><div class="td-sub">${p.descAr?.slice(0,50)||''}...</div></td>
      <td style="font-size:12px;color:var(--muted)">${p.nameFr}</td>
      <td><span class="badge b-cat">${p.categoryAr||'عام'}</span></td>
      <td><span class="badge b-price">${fmt(p.price)}</span></td>
      <td><span class="badge ${p.stock>0?'b-stock':'b-out'}">${p.stock>0?p.stock+' قطعة':'نفد المخزون'}</span></td>
      <td><label class="sw"><input type="checkbox" ${p.featured?'checked':''} onchange="toggleFeatured(${p.id},this.checked)"><span class="sl"></span></label></td>
      <td><div style="display:flex;gap:5px">
        <button class="btn btn-warning btn-xs" onclick="editProd(${p.id})">✏️ تعديل</button>
        <button class="btn btn-danger btn-xs" onclick="deleteProd(${p.id})">🗑️</button>
      </div></td>
    </tr>`).join(''):`<tr><td colspan="8" style="text-align:center;padding:40px;color:var(--muted)">لا توجد منتجات</td></tr>`;

  // Update filter dropdown
  const cats=[...new Set(S.products.map(p=>p.categoryAr))];
  const cf2=document.getElementById('prod-cat-filter');
  const cur2=cf2?.value;
  if(cf2){cf2.innerHTML='<option value="">كل الفئات</option>'+cats.map(c=>`<option value="${c}" ${c===cur2?'selected':''}>${c}</option>`).join('');}
  // Update datalists
  document.getElementById('dl-catAr').innerHTML=cats.map(c=>`<option value="${c}">`).join('');
  const catsFr=[...new Set(S.products.map(p=>p.categoryFr))];
  document.getElementById('dl-catFr').innerHTML=catsFr.map(c=>`<option value="${c}">`).join('');
}

