let editCatId2=null;
function openCatModal(){
  editCatId2=null;
  document.getElementById('cat-modal-title').textContent='➕ إضافة فئة جديدة';
  ['c-nameAr','c-nameFr','c-emoji'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('c-visible').checked=true;
  document.getElementById('catOverlay').classList.add('show');
}
function editCat2(id){
  if(!S.categories)return;
  const c=S.categories.find(x=>String(x.id)===String(id));if(!c)return;
  editCatId2=id;
  document.getElementById('cat-modal-title').textContent='✏️ تعديل الفئة';
  document.getElementById('c-nameAr').value=c.nameAr||'';
  document.getElementById('c-nameFr').value=c.nameFr||'';
  document.getElementById('c-emoji').value=c.emoji||'';
  document.getElementById('c-visible').checked=c.visible!==false;
  document.getElementById('catOverlay').classList.add('show');
}
function saveCat(){
  const nameAr=document.getElementById('c-nameAr').value.trim();
  const nameFr=document.getElementById('c-nameFr').value.trim();
  if(!nameAr){showToast('⚠️ الاسم العربي مطلوب');return;}
  if(!S.categories)S.categories=[];
  if(editCatId2){
    const i=S.categories.findIndex(c=>String(c.id)===String(editCatId2));
    const oldAr=S.categories[i].nameAr,oldFr=S.categories[i].nameFr;
    S.categories[i]={...S.categories[i],nameAr,nameFr:nameFr||nameAr,emoji:document.getElementById('c-emoji').value.trim()||'📦',visible:document.getElementById('c-visible').checked};
    S.products.forEach(p=>{if(p.categoryAr===oldAr){p.categoryAr=nameAr;p.categoryFr=nameFr||nameAr;}});
    showToast('✅ تم تعديل الفئة — المنتجات محدّثة');
  }else{
    if(S.categories.find(c=>c.nameAr===nameAr)){showToast('⚠️ الفئة موجودة مسبقاً');return;}
    S.categories.push({id:'cat'+Date.now(),nameAr,nameFr:nameFr||nameAr,emoji:document.getElementById('c-emoji').value.trim()||'📦',visible:document.getElementById('c-visible').checked});
    showToast('✅ تمت إضافة الفئة');
  }
  saveState();renderCats();
  document.getElementById('catOverlay').classList.remove('show');
}
function deleteCat(id){
  if(!S.categories)return;
  const c=S.categories.find(x=>String(x.id)===String(id));if(!c)return;
  if(!confirm('حذف فئة "'+c.nameAr+'"?\nالمنتجات ستنتقل لفئة "عام"'))return;
  S.products.forEach(p=>{if(p.categoryAr===c.nameAr){p.categoryAr='عام';p.categoryFr='Général';}});
  S.categories=S.categories.filter(x=>String(x.id)!==String(id));
  if(!S.categories.find(c=>c.nameAr==='عام'))S.categories.push({id:'cat-def',nameAr:'عام',nameFr:'Général',emoji:'📦',visible:true});
  saveState();renderCats();showToast('🗑️ تم حذف الفئة');
}
function toggleCatVis(id,val){
  if(!S.categories)return;
  const c=S.categories.find(x=>String(x.id)===String(id));
  if(c){c.visible=val;saveState();renderCats();showToast(val?'👁️ تم إظهار الفئة':'🙈 تم إخفاء الفئة');}
}

