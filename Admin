function doApplyAll(){
  const ov=document.getElementById('apply-office').value;
  const hv=document.getElementById('apply-home').value;
  if(!ov&&!hv){showToast('⚠️ أدخل سعراً واحداً على الأقل');return;}
  WILAYAS.forEach(w=>{
    const key=w.split(' - ')[0];
    if(ov){const el=document.getElementById('wpo-'+key);if(el){el.value=ov;el.classList.add('custom');}}
    if(hv){const el=document.getElementById('wph-'+key);if(el){el.value=hv;el.classList.add('custom');}}
  });
  document.getElementById('applyAllOverlay').classList.remove('show');
  showToast('✅ تم تطبيق السعر على 58 ولاية');
}

